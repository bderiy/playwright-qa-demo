{
  "name": "playwright-qa-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Senior QA Playwright framework demo with UI, API, auth, fixtures, mocking, and CI patterns.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:smoke": "playwright test --grep @smoke",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
